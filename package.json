  },
  "prisma": {
    "seed": "node server/seed.js"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "prisma": "^6.2.1",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.1"
  },
  "dependencies": {
