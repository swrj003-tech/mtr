# Hostinger Node.js App Passenger configuration
# Do not remove this file or Hostinger will not start the Node.js backend.

Options -Indexes
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Route traffic to Passenger App Root
  RewriteRule ^$ http://127.0.0.1:%{SERVER_PORT}/ [P,L]
  
  # Check if requested file or directory exists (like actual static files)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  
  # Proxy everything else to the Node.js application
  RewriteRule ^(.*)$ http://127.0.0.1:%{SERVER_PORT}/$1 [P,L]
</IfModule>
