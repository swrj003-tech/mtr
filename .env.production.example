# MRT International - Professional Production Environment
# Copy this to .env on your Hostinger server via HPanel

# Database: MySQL (Standard for Hostinger Business)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://your_db_user:your_db_password@localhost:3306/your_db_name"

# Security: Set a long random string for production
JWT_SECRET="generate_a_secure_random_string_here"

# Admin Access
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="set_a_strong_password_here"

# Global Config
NODE_ENV="production"
PORT=3000
